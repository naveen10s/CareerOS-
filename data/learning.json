{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Learning",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": { "type": "string" },
      "topic": { "type": "string" },
      "platform": { "type": "string" },
      "progress": { "type": "integer", "minimum": 0, "maximum": 100 },
      "targetDate": { "type": "string" },
      "relevance": { "type": "string" }
    }
  },
  "example": [
    {
      "id": "learn-1",
      "topic": "Interaction Design (UI/UX Principles)",
      "platform": "Interaction Design Foundation",
      "progress": 45,
      "targetDate": "2026-08",
      "relevance": "Translates business requirements into intuitive UI mockup requirements for design teams."
    }
  ]
}
